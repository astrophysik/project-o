class Counter is
    var count : 0
    this() is
    end

    method increment(step: Integer) : Unit is
        count := count.Plus(step)
        return Unit()
    end

    method get() : Integer => count

    method reset() : Unit is
        count := 0
        return Unit()
    end
end

class Main is
    this() is
        var c : Counter()
        c.increment(5)
        var io : IO()
        io.Print(c.get())
    end
end