class IntStack is
    var elements : ArrayInteger(0)
    var top : 0

    this(capacity: Integer) is
        elements := ArrayInteger(capacity)
        top := 0
    end

    method push(item: Integer) : Unit is
        if top.Less(elements.Len()) then
            elements.Set(top, item)
            top := top.Plus(1)
        end
        return Unit()
    end

    method pop() : Integer is
        top := top.Minus(1)
        return elements.Get(top)
    end

    method isEmpty() : Boolean => top.Equal(0)
end

class Main is
    this() is
        var st : IntStack(10)
        st.push(10)
        st.push(20)
        st.push(30)
        var io : IO()
        var x : st.pop()
        var y : st.pop()
        io.Print(x)
        io.Print(y)
    end
end