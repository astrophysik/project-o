class BubbleSort is
    this() is
    end

    method sort(arr: ArrayInteger) : Unit is
        var n : arr.Len()
        var i : Integer(1)

        while(i.Less(n.Minus(1))) loop
            var j : 0
            while(j.Less(n.Minus(1))) loop
                if arr.Get(j).Greater(arr.Get(j.Plus(1))) then
                    var tmp : arr.Get(j)
                    arr.Set(j, arr.Get(j.Plus(1)))
                    arr.Set(j.Plus(1), tmp)
                end
                j := j.Plus(1)
            end
            i := i.Plus(1)
        end
        return Unit()
    end
end

class Main is
    this() is
        var arr: ArrayInteger(5)
        arr.Set(0, 6)
        arr.Set(1, 2)
        arr.Set(2, 4)
        arr.Set(3, 2)
        arr.Set(4, 3)

        var Sort : BubbleSort()
        Sort.sort(arr)
        var io : IO()
        var n : arr.Len()
        var i : 0
        while i.Less(arr.Len()) loop
            var v : arr.Get(i)
            io.Print(v)
            i := i.Plus(1)
        end
    end
end
