class test is
  var first : Integer(0)
  var second : Integer(0)

  method getFirst() : Integer => first
  method setBoth(a:Integer, b:Integer) : Unit is
    first := a
    second := b
    return Unit()
  end

  this(a:Integer, b:Integer) is
    var i : this.setBoth(a,b)
  end
end

class Main is
  this() is
    var obj : test(Integer(0), Integer(0))
    var r : obj.setBoth(Integer(1), Integer(4))
    var result : obj.getFirst()
    var io : IO()
    io.Print(result.Equal(1))
  end
end